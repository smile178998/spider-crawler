# OpenAI-compatible API (optional — enables AI selector fallback)
OPENAI_API_KEY=sk-your-key-here

# Optional proxy for blocked sites (YouTube, Google, Twitter, etc.)
# SCRAPER_PROXY=http://127.0.0.1:7890

# Optional DNS-over-HTTPS (Cloudflare) — prevents DNS leaks when using a proxy
# SCRAPER_DOH=1
# DNS_OVER_HTTPS=true

# Optional cookie override (saved Chrome profile is preferred for all sites)
# BILI_COOKIE=SESSDATA=...; bili_jct=...

# Or use a compatible provider:
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# Ollama local example:
# AI_BASE_URL=http://127.0.0.1:11434/v1
# AI_MODEL=llama3.2
